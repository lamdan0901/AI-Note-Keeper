# ─────────────────────────────────────────────────────────────────────────────
# Appwrite — shared (used by scripts + Appwrite Functions)
# ─────────────────────────────────────────────────────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_DATABASE_ID=ai-note-keeper

# Admin API key — only needed for scripts/setup-appwrite-schema.ts
# Never expose this to the client apps
APPWRITE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Appwrite — mobile (Expo)
# Prefix required so Expo SDK bundles them at build time
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Appwrite — web (Vite)
# Prefix required so Vite's import.meta.env exposes them
# ─────────────────────────────────────────────────────────────────────────────
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Convex (existing — remove in Phase 9)
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_CONVEX_URL=
VITE_CONVEX_URL=

# ─────────────────────────────────────────────────────────────────────────────
# AI Voice Capture
# ─────────────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_MODEL_PARSE=
NVIDIA_MODEL_CLARIFY=
NVIDIA_TRANSCRIPT_ZERO_RETENTION=true

# ─────────────────────────────────────────────────────────────────────────────
# Firebase / FCM (for Appwrite push-notification function)
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=
