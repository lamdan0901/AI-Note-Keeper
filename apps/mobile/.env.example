# Expo public env vars for Convex + device identity.
EXPO_PUBLIC_CONVEX_URL=

# Express auth API base URL (for Phase 2 auth/session continuity).
# Example: http://10.0.2.2:3000
EXPO_PUBLIC_AUTH_API_URL=

EXPO_PUBLIC_USER_ID=
# Optional stable UUIDv4 for the device.
EXPO_PUBLIC_DEVICE_ID=

# Mobile voice capture rollout flags (disabled by default).
EXPO_PUBLIC_MOBILE_VOICE_CAPTURE_V1=
EXPO_PUBLIC_MOBILE_VOICE_CLARIFICATION_V1=
