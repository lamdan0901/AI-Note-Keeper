{
  "main": "index.js",
  "expo": {
    "name": "AI Note Keeper",
    "slug": "ai-note-keeper",
    "scheme": "ainotekeeper",
    "platforms": ["ios", "android"],
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.andersonho.ainotekeeper",
      "googleServicesFile": "./google-services.json",
      "permissions": ["SCHEDULE_EXACT_ALARM", "RECORD_AUDIO"]
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow AI Note Keeper to access your microphone for hold-to-talk voice capture.",
          "speechRecognitionPermission": "Allow AI Note Keeper to transcribe your speech for note capture.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "extra": {
      "eas": {
        "projectId": "d0a52eb8-e31a-41c2-b747-bd7b606a69db"
      }
    }
  }
}
