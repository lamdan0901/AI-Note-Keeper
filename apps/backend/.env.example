PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_note_keeper
JWT_ISSUER=ai-note-keeper-dev
JWT_AUDIENCE=ai-note-keeper-clients
JWT_ACCESS_SECRET=replace-with-a-32-plus-character-secret
JWT_REFRESH_SECRET=replace-with-a-32-plus-character-secret
LEGACY_UPGRADE_SECRET=replace-with-a-32-plus-character-secret
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# Optional temporary migration controls for legacy userId-only upgrade-session path.
# Keep disabled unless actively migrating old clients.
# ALLOW_LEGACY_USERID_UPGRADE_WITHOUT_TOKEN=false
# LEGACY_USERID_UPGRADE_TOKENLESS_UNTIL=2026-12-31T23:59:59.000Z
# ALLOW_LEGACY_USERID_UPGRADE_WITHOUT_TOKEN_IN_PRODUCTION=false
