# Vite env vars for Convex client configuration.
VITE_CONVEX_URL=

# Express API base URL used by web transport.
# Example: http://localhost:3000
VITE_API_BASE_URL=

# Express auth API base URL (for auth/session continuity).
# Example: http://localhost:3000
VITE_AUTH_API_BASE_URL=

# Cutover rollout gate settings.
# Allowed cohorts: shadow, pilot, ramp, full
VITE_CUTOVER_COHORT=shadow
VITE_CUTOVER_REQUIRE_PARITY=true
VITE_CUTOVER_REQUIRE_SLO=true
VITE_CUTOVER_REQUIRE_ROLLBACK_DRILL=true
